{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug: Train GRPO",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/grpo_train.py",
            "console": "integratedTerminal",
            "env": {
                "TOKENIZERS_PARALLELISM": "true",
                // "CUDA_VISIBLE_DEVICES": "0"
            },
            "justMyCode": false
        },
        {
            "name": "Debug: Train GRPO (DDP, auto GPUs)",
            "type": "debugpy",
            "request": "launch",
            "module": "torch.distributed.run",
            "args": [
                "--standalone",
                "--nnodes=1",
                "--nproc_per_node=1",
                "${workspaceFolder}/train.py"
            ],
            "console": "integratedTerminal",
            "env": {
                "TOKENIZERS_PARALLELISM": "true",
                "CUDA_LAUNCH_BLOCKING": "1"
            },
            "subProcess": true,
            "justMyCode": false,

        },
        {
            "name": "Debug: SL",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/sl.py",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}